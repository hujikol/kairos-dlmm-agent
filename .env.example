# ─── Required ────────────────────────────────────────────────────
WALLET_PRIVATE_KEY=your_base58_or_json_array_wallet_key
RPC_URL=https://api.mainnet-beta.solana.com
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Trading ──────────────────────────────────────────────────────
DRY_RUN=true
METEORA_COMPUTE_UNIT_LIMIT=1400000
METEORA_SLIPPAGE_BPS=1000

# ─── LLM ─────────────────────────────────────────────────────────
LLM_MODEL=minimax/minimax-01
LLM_BASE_URL=
LLM_API_KEY=openai
LLM_FALLBACK_MODEL=stepfun/step-3.5-flash:free

# ─── Telegram ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789

# ─── External Services ──────────────────────────────────────────
HELIUS_API_KEY=
JUPITER_DATAAPI_BASE_URL=
POOL_DISCOVERY_API_BASE=
LPAGENT_API_KEY=

# ─── Agent Meridian / Hive Mind (experimental) ──────────────────
AGENT_MERIDIAN_API_URL=https://api.agentmeridian.xyz/api
HIVE_MIND_PUBLIC_API_KEY=
# lpAgentRelayEnabled=true  # set in user-config.json, not here

# ─── Behavior ───────────────────────────────────────────────────
CAVEMAN_ENABLED=false
HEALTH_PORT=3030
SENTRY_DSN=
