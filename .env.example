# kairos — Environment Variables
# Copy this file to .env and fill in your values.
# cp .env.example .env

# ─── Required ───────────────────────────────────────────────────

# Solana wallet private key (base58 format or JSON array)
# NEVER commit this file — it's gitignored
WALLET_PRIVATE_KEY=your_base58_private_key

# Solana RPC endpoint (Helius recommended)
# Must support DLMM pool queries and transaction sending
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Sentry error tracking DSN (optional — leave empty to disable)
SENTRY_DSN=

# LLM API key (OpenRouter or compatible)
# https://openrouter.ai
LLM_API_KEY=sk-or-v1-your_key_here

# ─── LLM Configuration ─────────────────────────────────────────

# Override the default model name
# Full list of OpenRouter models: https://openrouter.ai/models
# Default per-role models: openrouter/healer-alpha
LLM_MODEL=openrouter/healer-alpha

# Use a different API-compatible LLM endpoint (e.g., LM Studio, Ollama)
# Leave empty or remove to use default OpenRouter
LLM_BASE_URL=

# Fallback model on 502/503/529 provider errors
LLM_FALLBACK_MODEL=stepfun/step-3.5-flash:free

# LLM timeout in milliseconds (default: 300000 = 5 minutes)
LLM_TIMEOUT_MS=300000

# Agent loop wall-clock timeout in seconds (default: 480 = 8 minutes)
MAX_WALL_CLOCK_MS=480

# LLM Logging — debug, info, warn, error (default: info)
LOG_LEVEL=info

# ─── API Base URLs ─────────────────────────────────────────────
# Override defaults only if using custom endpoints.

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MINIMAX_BASE_URL=https://api.minimax.io/v1
OPENAI_BASE_URL=https://api.openai.com/v1
LOCAL_LLM_BASE_URL=http://localhost:1234/v1

JUPITER_DATAPI_BASE_URL=https://datapi.jup.ag/v1
JUPITER_PRICE_API_URL=https://api.jup.ag/price/v3
JUPITER_ULTRA_API_URL=https://api.jup.ag/ultra/v1
JUPITER_QUOTE_API_URL=https://api.jup.ag/swap/v1

POOL_DISCOVERY_API_BASE=https://pool-discovery-api.datapi.meteora.ag
METEORA_DLMM_API_BASE=https://dlmm.datapi.meteora.ag

OKX_API_BASE=https://web3.okx.com
LPAGENT_API_BASE=https://api.lpagent.io/open-api/v1
HELIUS_API_BASE=https://api.helius.xyz

# ─── API Keys (External Services) ─────────────────────────────

# Helius API key — wallet balance lookups, enriched portfolio data
HELIUS_API_KEY=

# Jupiter API key — enhanced token audit pipeline
JUPITER_API_KEY=

# Telegram bot token — notifications and remote control
# Create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Telegram chat ID — auto-filled on first bot message, leave empty for now
TELEGRAM_CHAT_ID=

# LP Agent API key — top LPer study via LPAgent service
# (comma-separated if multiple keys for rotation)
LPAGENT_API_KEY=

# Hive Mind — optional collective intelligence server sync
# Get YOUR_TOKEN from the private Telegram discussion
HIVE_MIND_URL=
HIVE_MIND_API_KEY=

# ─── Meteora / Trading ──────────────────────────────────────────

# Priority fee in micro-lamports for Meteora transactions (default: 50000)
PRIORITY_MICRO_LAMPORTS=50000

# Compute unit limit for Meteora transactions (default: 1400000)
METEORA_COMPUTE_UNIT_LIMIT=1400000

# Slippage in basis points for Meteora deploys (default: 1000 = 10%)
METEORA_SLIPPAGE_BPS=1000

# Positions cache TTL in ms (default: 300000 = 5 minutes)
METEORA_POSITIONS_CACHE_TTL_MS=300000

# Post-close RPC sync wait in ms (default: 5000)
METEORA_CLOSE_SYNC_WAIT_MS=5000

# Post-close retry delay in ms (default: 3000)
METEORA_CLOSE_RETRY_DELAY_MS=3000

# ─── Solana ─────────────────────────────────────────────────────

# Backoff base delay in ms for rate-limited RPC calls (default: 1000)
SOLANA_BACKOFF_BASE_DELAY_MS=1000

# Backoff max delay in ms (default: 30000)
SOLANA_BACKOFF_MAX_DELAY_MS=30000

# ─── Notifications ──────────────────────────────────────────────

# Delay between outbound Telegram messages in ms (default: 1500)
TELEGRAM_MSG_DELAY_MS=1500

# Telegram long-polling timeout in ms (default: 35000)
TELEGRAM_POLL_TIMEOUT_MS=35000

# Briefing lookback window in ms (default: 86400000 = 24 hours)
BRIEFING_LOOKBACK_MS=86400000

# ─── Hive Mind ──────────────────────────────────────────────────

# Sync debounce window in ms (default: 300000 = 5 minutes)
HIVE_MIND_SYNC_DEBOUNCE_MS=300000

# GET request timeout in ms (default: 5000)
HIVE_MIND_GET_TIMEOUT_MS=5000

# POST request timeout in ms (default: 10000)
HIVE_MIND_POST_TIMEOUT_MS=10000

# ─── LPAGENT ────────────────────────────────────────────────────

# Buffer added to LPAGENT rate limit window in ms (default: 1000)
LPAGENT_RATE_LIMIT_BUFFER_MS=1000

# ─── Cache / Performance ────────────────────────────────────────

# Helius balance cache TTL in ms (default: 300000 = 5 minutes)
HELIUS_BALANCE_CACHE_TTL_MS=300000

# Watchdog poll interval in ms (default: 60000 = 1 minute)
WATCHDOG_POLL_INTERVAL_MS=60000

# ─── Safety ─────────────────────────────────────────────────────

# Set true to skip all on-chain transactions (safe to experiment)
# ALWAYS start with true until you verify agent behavior
DRY_RUN=true

# ─── Behavior ───────────────────────────────────────────────────

# Set true to enable caveman-mode prompt compression (saves tokens)
# Persisted via /caveman command in REPL
CAVEMAN_ENABLED=false