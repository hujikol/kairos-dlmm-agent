# Meridian — Environment Variables
# Copy this file to .env and fill in your values.
# cp .env.example .env

# ─── Required ───────────────────────────────────────────────────

# Solana wallet private key (base58 format or JSON array)
# NEVER commit this file — it's gitignored
WALLET_PRIVATE_KEY=your_base58_private_key

# Solana RPC endpoint (Helius recommended)
# Must support DLMM pool queries and transaction sending
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# LLM API key (OpenRouter or compatible)
# https://openrouter.ai
LLM_API_KEY=sk-or-v1-your_key_here

# ─── LLM Settings ──────────────────────────────────────────────

# Override the default model name
# Full list of OpenRouter models: https://openrouter.ai/models
# Default per-role models: openrouter/healer-alpha
LLM_MODEL=openrouter/healer-alpha

# Use a different API-compatible LLM endpoint (e.g., LM Studio, Ollama)
# Leave empty or remove to use default OpenRouter
LLM_BASE_URL=

# LLM Logging — debug, info, warn, error (default: info)
LOG_LEVEL=info

# ─── Optional — Enhanced Features ──────────────────────────────

# Helius API key — wallet balance lookups, enriched portfolio data
HELIUS_API_KEY=

# Jupiter API key — enhanced token audit pipeline
JUPITER_API_KEY=

# Telegram bot token — notifications and remote control
# Create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Telegram chat ID — auto-filled on first bot message, leave empty for now
TELEGRAM_CHAT_ID=

# Discord listener — selfbot for LP Army channel signals
# Get token from browser DevTools → Network tab (not a bot token)
# See discord-listener/README.md for setup instructions
DISCORD_USER_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_IDS=channel1,channel2
DISCORD_MIN_FEES_SOL=5

# LP Agent API key — top LPer study via LPAgent service
# (comma-separated if multiple keys for rotation)
LPAGENT_API_KEY=

# Hive Mind — optional collective intelligence server sync
# Get YOUR_TOKEN from the private Telegram discussion
HIVE_MIND_URL=
HIVE_MIND_API_KEY=

# ─── Optional — Advanced ───────────────────────────────────────

# Solana priority fee micro-lamports per compute unit
# Default: 50000. Increase during network congestion
# PRIORITY_MICRO_LAMPORTS=50000

# ─── Safety ─────────────────────────────────────────────────────

# Set true to skip all on-chain transactions (safe to experiment)
# ALWAYS start with true until you verify agent behavior
DRY_RUN=true
