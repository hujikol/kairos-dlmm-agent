{
  "name": "kairos-dllm-agent",
  "version": "1.0.0",
  "type": "module",
  "description": "Autonomous DLMM LP agent for Meteora pools on Solana — Kairos fork of Meridian",
  "license": "MIT",
  "main": "src/index.js",
  "bin": {
    "meridian": "src/cli.js"
  },
  "scripts": {
    "setup": "node src/setup.js",
    "start": "node src/index.js",
    "dev": "DRY_RUN=true node src/index.js",
    "test": "node --test 'test-*.js' '*.test.js'",
    "test:watch": "node --test --watch test-*.js",
    "test:screen": "node test/test-screening.js",
    "test:agent": "DRY_RUN=true node test/test-agent.js",
    "postinstall": "node scripts/patch-anchor.js"
  },
  "dependencies": {
    "@meteora-ag/dlmm": "1.9.4",
    "@sentry/node": "10.48.0",
    "@sentry/profiling-node": "10.48.0",
    "@solana/spl-token": "0.4.14",
    "@solana/web3.js": "1.98.4",
    "sql.js": "^1.11.0",
    "bn.js": "5.2.3",
    "bs58": "5.0.0",
    "dotenv": "17.3.1",
    "jsonrepair": "3.13.3",
    "croner": "^10.0.0",
    "openai": "6.34.0",
    "write-file-atomic": "7.0.1"
  },
  "engines": {
    "node": ">=20.17.0 || >=22.9.0"
  },
  "overrides": {
    "debug": "^4.3.0"
  }
}
