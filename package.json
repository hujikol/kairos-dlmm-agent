{
  "name": "dlmm-agent",
  "version": "1.0.0",
  "type": "module",
  "description": "Autonomous DLMM LP agent for Meteora pools on Solana",
  "main": "src/index.js",
  "bin": {
    "meridian": "src/cli.js"
  },
  "scripts": {
    "setup": "node src/setup.js",
    "start": "node src/index.js",
    "dev": "DRY_RUN=true node src/index.js",
    "test": "node --test test-*.js",
    "test:watch": "node --test --watch test-*.js",
    "test:screen": "node test/test-screening.js",
    "test:agent": "DRY_RUN=true node test/test-agent.js",
    "postinstall": "node scripts/patch-anchor.js"
  },
  "dependencies": {
    "@sentry/node": "^8.0.0",
    "@sentry/profiling-node": "^8.0.0",
    "@meteora-ag/dlmm": "1.9.4",
    "@solana/spl-token": "0.4.14",
    "@solana/web3.js": "1.98.4",
    "better-sqlite3": "12.8.0",
    "bn.js": "5.2.3",
    "bs58": "5.0.0",
    "dotenv": "17.3.1",
    "jsonrepair": "3.13.3",
    "node-cron": "3.0.3",
    "openai": "4.104.0",
    "write-file-atomic": "7.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
