{
  "name": "kairos-dlmm-agent",
  "version": "2.0.0",
  "type": "module",
  "description": "Autonomous DLMM LP agent for Meteora pools on Solana — Kairos fork of Meridian",
  "license": "MIT",
  "main": "src/index.js",
  "bin": {
    "meridian": "src/cli.js"
  },
  "scripts": {
    "setup": "node src/setup.js",
    "start": "node src/index.js",
    "dev": "DRY_RUN=true node src/index.js",
    "self-update": "git pull && npm install && pm2 restart kairos || true",
    "test": "c8 node --test test/test-*.js test/*.test.js",
    "test:watch": "node --test --watch test/test-*.js test/*.test.js",
    "test:screen": "node test/test-screening.js",
    "test:agent": "DRY_RUN=true node test/test-agent.js",
    "lint": "eslint src/ test/",
    "postinstall": "node scripts/patch-anchor.js"
  },
  "dependencies": {
    "@meteora-ag/dlmm": "1.9.6",
    "@sentry/node": "10.49.0",
    "@sentry/profiling-node": "10.49.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "ajv": "^8.20.0",
    "better-sqlite3": "^12.9.0",
    "bs58": "5.0.0",
    "croner": "^10.0.0",
    "dotenv": "17.4.2",
    "jsonrepair": "3.14.0",
    "openai": "6.34.0",
    "write-file-atomic": "7.0.1"
  },
  "devDependencies": {
    "@eslint/config-array": "^0.23.5",
    "c8": "^11.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=20.17.0 || >=22.9.0"
  },
  "overrides": {
    "debug": "^4.3.0",
    "@coral-xyz/anchor": "0.31.0",
    "@meteora-ag/dlmm": "1.9.6"
  }
}
